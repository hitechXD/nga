# Copy this file to .env and fill in real values. Never commit the real .env file.

# Password to log into the admin panel at /admin.html
ADMIN_PASSWORD=changeme

# Secret UroPay gives you for verifying webhook signatures (see their dashboard/docs)
UROPAY_WEBHOOK_SECRET=replace_me
UROPAY_API_KEY=replace_me

# Your Minecraft server's RCON details (enable RCON in server.properties)
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=replace_me

# Port the backend itself runs on
PORT=3000
